# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender (must be on hashbrando.com — do not use onboarding@resend.dev)
RESEND_FROM_EMAIL=HasBrando <support@hashbrando.com>

# Inbox for contact form lead notifications
CONTACT_TO_EMAIL=support@hashbrando.com

# Rate limiting (default: 50 requests / hour per IP)
CONTACT_RATE_LIMIT_DISABLED=true
# CONTACT_RATE_LIMIT_MAX=50
# CONTACT_RATE_LIMIT_WINDOW_MS=3600000

# ── Google Sheets (optional — form works without these) ──
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Telegram alerts (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
